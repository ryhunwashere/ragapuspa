{
  "name": "ragapuspa",
  "type": "module",
  "version": "0.1",
  "scripts": {
    "astro": "astro",
    "dev": "astro dev --host",
    "create-gallery": "rm -rf src/assets/gallery && mkdir -p src/assets/gallery",
    "generate-gallery": "bun src/scripts/generate-gallery-v2.ts",
    "build": "bun run create-gallery && bun run generate-gallery && astro build && rm -r dist/_astro/*.jpg",
    "preview": "astro preview --host"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.1.0",
    "@astrojs/ts-plugin": "^1.10.7",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.3.0",
    "gsap": "^3.15.0",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.6.0",
    "@types/bun": "^1.3.13"
  }
}
